# Pear Autoreplies — environment variables
# Copy to `.env` for local dev. Never commit `.env`.
# In production, these are loaded via Docker secrets / systemd EnvironmentFile.

# ---- Service ----
APP_ENV=development                             # development | staging | production
LOG_LEVEL=INFO

# ---- Bearer token for /admin/* endpoints ----
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_TOKEN=replace-me-with-a-long-random-string

# ---- Pub/Sub push verification ----
PUBSUB_AUDIENCE=https://autoreplies.pearnyc.com/pubsub/inbox
PUBSUB_SERVICE_ACCOUNT_EMAIL=pubsub-pusher@pearnyc-XXXXXX.iam.gserviceaccount.com

# ---- Google service account (domain-wide delegation) ----
# Path inside the container; mount the JSON via docker-compose or systemd.
GOOGLE_APPLICATION_CREDENTIALS=/etc/pear-autoreply/sa.json

# ---- Anthropic ----
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ---- Airtable ----
# PAT scoped to the Pear Tracker base only.
AIRTABLE_TOKEN=patXXXXXXXXXXXXXX.XXXXXXXXXXXXXX
AIRTABLE_BASE_ID=appwPKlnV6YtbIjWz
# Table and field IDs live in src/autoreplies/services/airtable_schema.py —
# do not add them here. Only the base IDs above belong in .env.

# Set to a staging base ID for local dev. Leave blank to use prod.
AIRTABLE_STAGING_BASE_ID=

# ---- Supabase ----
SUPABASE_URL=https://fuacxndojzybijrqdbym.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...

# ---- Slack ----
# Bot scope: chat:write
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL=#platform-leads

# ---- Redis (queue + idempotency state) ----
REDIS_URL=redis://redis:6379/0
DEDUP_TTL_DAYS=30

# ---- Send timing ----
QUIET_HOURS_TZ=America/New_York
QUIET_HOURS_START=23           # 23:00 (11 PM)
QUIET_HOURS_END=7              # 07:00 (7 AM)
SEND_JITTER_MIN_SECONDS=120    # 2 min
SEND_JITTER_MAX_SECONDS=300    # 5 min

# ---- Match thresholds ----
APARTMENT_FUZZY_MATCH_THRESHOLD=92

# ---- Harness ----
# Test Airtable base (appmSm1FyerysvtcX). The same AIRTABLE_TOKEN PAT covers both bases.
AIRTABLE_TEST_BASE_ID=appmSm1FyerysvtcX
# How often the harness poller checks each mailbox (seconds).
HARNESS_POLL_INTERVAL_SECONDS=60
# On first start, how far back to look for messages (seconds).
HARNESS_BOOTSTRAP_LOOKBACK_SECONDS=60
# SQLite state file path — mounted via harness_state volume in docker-compose.
HARNESS_STATE_PATH=/var/lib/pear-autoreply/harness.sqlite
